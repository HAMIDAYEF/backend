generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model DrivingSchool {
  id          Int          @id @default(autoincrement())
  name        String       @db.VarChar(100)
  logo        String?      @db.VarChar(255)
  address     String?      @db.VarChar(255)
  phone       String?      @db.VarChar(20)
  email       String?      @db.VarChar(150)
  createdAt   DateTime?    @default(now()) @map("created_at") @db.DateTime(0)
  admins      Admin[]
  candidates  Candidate[]
  instructors Instructor[]

  @@map("driving_school")
}

model Admin {
  id              Int           @id @default(autoincrement())
  firstName       String        @map("first_name") @db.VarChar(100)
  lastName        String        @map("last_name") @db.VarChar(100)
  email           String        @db.VarChar(150)
  phone           String        @db.VarChar(13)
  password        String        @db.VarChar(70)
  drivingSchoolId Int           @map("driving_school_id")
  createdAt       DateTime?     @default(now()) @map("created_at") @db.DateTime(0)
  drivingSchool   DrivingSchool @relation(fields: [drivingSchoolId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "admin_ibfk_1")
  payments        Payment[]

  @@index([drivingSchoolId], map: "driving_school_id")
  @@map("admin")
}

model Instructor {
  id              Int                  @id @default(autoincrement())
  firstName       String               @map("first_name") @db.VarChar(100)
  lastName        String               @map("last_name") @db.VarChar(100)
  email           String               @db.VarChar(150)
  password        String               @db.VarChar(150)
  phone           String?              @db.VarChar(20)
  specialty       String?              @db.VarChar(100)
  hireDate        DateTime?            @map("hire_date") @db.Date
  drivingSchoolId Int                  @map("driving_school_id")
  createdAt       DateTime?            @default(now()) @map("created_at") @db.DateTime(0)
  candidates      Candidate[]
  drivingSchool   DrivingSchool        @relation(fields: [drivingSchoolId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "instructor_ibfk_1")
  schedules       InstructorSchedule[]
  session         Session[]

  @@index([drivingSchoolId], map: "driving_school_id")
  @@map("instructor")
}

model Candidate {
  id               Int           @id @default(autoincrement())
  firstName        String        @map("first_name") @db.VarChar(20)
  lastName         String        @map("last_name") @db.VarChar(20)
  birthDate        DateTime      @map("birth_date") @db.Date
  email            String?       @db.VarChar(150)
  phone            String?       @db.VarChar(10)
  password         String        @db.VarChar(150)
  licenseType      String        @map("license_type") @db.VarChar(2)
  address          String?       @db.VarChar(255)
  bloodType        String        @map("blood_type") @db.VarChar(3)
  registrationDate DateTime?     @map("registration_date") @db.Date
  totalPrice       Decimal?      @map("total_price") @db.Decimal(10, 2)
  instructorId     Int           @map("instructor_id")
  drivingSchoolId  Int           @map("driving_school_id")
  createdAt        DateTime?     @default(now()) @map("created_at") @db.DateTime(0)
  instructor       Instructor    @relation(fields: [instructorId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "candidate_ibfk_1")
  drivingSchool    DrivingSchool @relation(fields: [drivingSchoolId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "candidate_ibfk_2")
  exams            Exam[]
  payments         Payment[]
  sessions         Session[]

  @@index([drivingSchoolId], map: "driving_school_id")
  @@index([instructorId], map: "instructor_id")
  @@map("candidate")
}

model Exam {
  id          Int       @id @default(autoincrement())
  examDate    DateTime  @map("exam_date") @db.Date
  examType    String    @map("exam_type") @db.VarChar(50)
  status      String?   @db.VarChar(50)
  candidateId Int       @map("candidate_id")
  createdAt   DateTime? @default(now()) @map("created_at") @db.DateTime(0)
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "exam_ibfk_1")

  @@index([candidateId], map: "candidate_id")
  @@map("exam")
}

model InstructorSchedule {
  id           Int        @id @default(autoincrement())
  scheduleDate DateTime?  @map("schedule_date") @db.Date
  scheduleDay  Int?       @map("schedule_day")
  startTime    DateTime   @map("start_time") @db.Time(0)
  endTime      DateTime   @map("end_time") @db.Time(0)
  isAvailable  Boolean    @map("is_available")
  instructorId Int        @map("instructor_id")
  createdAt    DateTime?  @default(now()) @map("created_at") @db.DateTime(0)
  instructor   Instructor @relation(fields: [instructorId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "instructor_schedule_ibfk_1")

  @@index([instructorId], map: "instructor_id")
  @@map("instructor_schedule")
}

model Payment {
  id            Int       @id @default(autoincrement())
  paymentTime   DateTime? @map("payment_time") @db.DateTime(0)
  amount        Decimal   @db.Decimal(10, 2)
  paymentMethod String    @map("payment_method") @db.VarChar(50)
  candidateId   Int       @map("candidate_id")
  createdBy     Int?      @map("created_by")
  createdAt     DateTime? @default(now()) @map("created_at") @db.DateTime(0)
  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "payment_ibfk_1")
  admin         Admin?    @relation(fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "payment_ibfk_2")

  @@index([candidateId], map: "candidate_id")
  @@index([createdBy], map: "created_by")
  @@map("payment")
}

model Session {
  id            Int        @id @default(autoincrement())
  startTime     DateTime   @map("start_time") @db.DateTime(0)
  endTime       DateTime   @map("end_time") @db.DateTime(0)
  attended      Boolean?
  status        String?    @db.VarChar(50)
  candidateId   Int        @map("candidate_id")
  instructor_id Int
  createdAt     DateTime?  @default(now()) @map("created_at") @db.DateTime(0)
  candidate     Candidate  @relation(fields: [candidateId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "session_ibfk_1")
  instructor    Instructor @relation(fields: [instructor_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "session_ibfk_2")

  @@index([candidateId], map: "candidate_id")
  @@index([instructor_id], map: "instructor_id")
  @@map("session")
}
