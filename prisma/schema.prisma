generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model DrivingSchool {
  id          Int          @id @default(autoincrement())
  name        String
  logo        String?
  address     String?
  phone       String?
  email       String?
  createdAt   DateTime     @default(now()) @map("created_at")
  admins      Admin[]
  candidates  Candidate[]
  instructors Instructor[]

  @@map("driving_school")
}

model Admin {
  id              Int           @id @default(autoincrement())
  firstName       String        @map("first_name")
  lastName        String        @map("last_name")
  email           String
  phone           String
  password        String
  drivingSchoolId Int           @map("driving_school_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  drivingSchool   DrivingSchool @relation(fields: [drivingSchoolId], references: [id])
  payments        Payment[]

  @@index([drivingSchoolId], map: "admin_driving_school_id_fkey")
  @@map("admin")
}

model Instructor {
  id              Int                  @id @default(autoincrement())
  firstName       String               @map("first_name")
  lastName        String               @map("last_name")
  email           String
  password        String
  phone           String?
  hireDate        DateTime?            @map("hire_date")
  drivingSchoolId Int                  @map("driving_school_id")
  createdAt       DateTime             @default(now()) @map("created_at")
  candidates      Candidate[]
  drivingSchool   DrivingSchool        @relation(fields: [drivingSchoolId], references: [id])
  schedules       InstructorSchedule[]

  @@index([drivingSchoolId], map: "instructor_driving_school_id_fkey")
  @@map("instructor")
}

model Candidate {
  id               Int           @id @default(autoincrement())
  firstName        String        @map("first_name")
  lastName         String        @map("last_name")
  birthDate        DateTime      @map("birth_date")
  email            String?
  phone            String?
  password         String
  licenseType      String        @map("license_type")
  address          String?
  bloodType        String        @map("blood_type")
  registrationDate DateTime?     @map("registration_date")
  totalPrice       Float?        @map("total_price")
  instructorId     Int           @map("instructor_id")
  drivingSchoolId  Int           @map("driving_school_id")
  createdAt        DateTime      @default(now()) @map("created_at")
  drivingSchool    DrivingSchool @relation(fields: [drivingSchoolId], references: [id])
  instructor       Instructor    @relation(fields: [instructorId], references: [id])
  exams            Exam[]
  payments         Payment[]
  sessions         Session[]

  @@index([drivingSchoolId], map: "candidate_driving_school_id_fkey")
  @@index([instructorId], map: "candidate_instructor_id_fkey")
  @@map("candidate")
}

model Exam {
  id          Int       @id @default(autoincrement())
  examDate    DateTime  @map("exam_date")
  examType    String    @map("exam_type")
  status      String?
  candidateId Int       @map("candidate_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  candidate   Candidate @relation(fields: [candidateId], references: [id])

  @@index([candidateId], map: "exam_candidate_id_fkey")
  @@map("exam")
}

model InstructorSchedule {
  id           Int        @id @default(autoincrement())
  scheduleDate DateTime?  @map("schedule_date")
  scheduleDay  Int?       @map("schedule_day")
  startTime    DateTime   @map("start_time")
  endTime      DateTime   @map("end_time")
  isAvailable  Boolean    @map("is_available")
  instructorId Int        @map("instructor_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  instructor   Instructor @relation(fields: [instructorId], references: [id])

  @@index([instructorId], map: "instructor_schedule_instructor_id_fkey")
  @@map("instructor_schedule")
}

model Payment {
  id            Int       @id @default(autoincrement())
  paymentTime   DateTime? @map("payment_time")
  amount        Float
  paymentMethod String    @map("payment_method")
  candidateId   Int       @map("candidate_id")
  createdBy     Int?      @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  candidate     Candidate @relation(fields: [candidateId], references: [id])
  admin         Admin?    @relation(fields: [createdBy], references: [id])

  @@index([candidateId], map: "payment_candidate_id_fkey")
  @@index([createdBy], map: "payment_created_by_fkey")
  @@map("payment")
}

model Session {
  id          Int          @id @default(autoincrement())
  startTime   DateTime     @map("start_time")
  endTime     DateTime     @map("end_time")
  attended    Boolean?
  status      String?
  candidateId Int          @map("candidate_id")
  createdAt   DateTime     @default(now()) @map("created_at")
  typeSession SessionType? @map("type_session")
  candidate   Candidate    @relation(fields: [candidateId], references: [id])

  @@index([candidateId], map: "session_candidate_id_fkey")
  @@map("session")
}

enum SessionType {
  code
  creneau
  conduite
}
